RUST_LOG=info
DATABASE_URL=postgres://verdict:verdict@127.0.0.1:5432/verdict
GEMINI_API_KEY=replace-with-real-key
GEMINI_MODEL=gemini-2.5-flash-lite
FDA_PDF_MAX_BYTES=26214400
FDA_PDF_ALLOWED_HOST_SUFFIXES=fda.gov
FDA_PDF_ALLOW_INSECURE_LOCALHOST=false

# openFDA historical-event ingestion (Phase 3 PR A).
# API key is REQUIRED, not optional: the unauthenticated daily limit
# (1,000 requests per IP) cannot complete a meaningful ingestion run.
# Sign up free at https://open.fda.gov/apis/authentication/.
OPENFDA_API_KEY=replace-with-real-key
OPENFDA_BASE_URL=https://api.fda.gov
# Polite delay between paged requests in milliseconds (default 250).
OPENFDA_PAGE_DELAY_MS=250
